{
  "name": "astro-fontkit",
  "version": "0.1.0",
  "description": "Astro-native font loading for Google Fonts and local font files.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./google": {
      "types": "./dist/google.d.ts",
      "default": "./dist/google.js"
    },
    "./local": {
      "types": "./dist/local.d.ts",
      "default": "./dist/local.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/google.ts src/local.ts src/middleware.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "astro": "^6.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
